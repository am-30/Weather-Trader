# =============================================================================
# Kalshi Weather Trader — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (set automatically by setup_vm.sh — no changes needed on the VM)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Kalshi API credentials
# Get these from: https://kalshi.com → Account → API
# -----------------------------------------------------------------------------

# Short key ID string (looks like: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
KALSHI_ACCESS_KEY=your-key-id-here

# Full RSA private key — paste the entire block on one line using \n for newlines
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# "demo" to use Kalshi's paper trading environment, "prod" for real money
KALSHI_ENV=demo

# -----------------------------------------------------------------------------
# Trading behaviour
# -----------------------------------------------------------------------------

# true = never place real orders (safe default; switch to false only when ready)
DRY_RUN=true

# Minimum predicted edge (as a fraction, e.g. 0.05 = 5%) required to trade
EDGE_THRESHOLD=0.05

# Maximum dollar amount to risk on a single trade
MAX_TRADE_SIZE_USD=50.0

# Maximum number of contracts to hold open in one market
MAX_CONTRACTS_PER_MARKET=10

# Kelly criterion fraction (0.25 = quarter-Kelly, conservative)
KELLY_FRACTION=0.25

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# DEBUG, INFO, WARNING, ERROR, or CRITICAL
LOG_LEVEL=INFO
