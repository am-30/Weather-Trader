# ============================================================
# Kalshi API credentials
# Sign up at https://kalshi.com and generate an API key
# ============================================================
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# Set to "demo" or "prod" — controls which Kalshi environment is used
KALSHI_ENV=demo

# ============================================================
# Database — provided automatically by Replit
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================================
# NWS (National Weather Service) API — free, no key required
# Station KBOS = Boston Logan Airport
# ============================================================
NWS_STATION=KBOS
NWS_API_BASE_URL=https://api.weather.gov

# ============================================================
# Trading parameters
# ============================================================
# Maximum dollar amount to risk per trade
MAX_TRADE_SIZE_USD=50.0

# Minimum edge (expected value - cost) to place a trade, in cents
MIN_EDGE_CENTS=3.0

# Maximum number of open contracts per market
MAX_CONTRACTS_PER_MARKET=10

# ============================================================
# Scheduler intervals (in minutes)
# ============================================================
WEATHER_FETCH_INTERVAL_MINUTES=15
MARKET_FETCH_INTERVAL_MINUTES=5
FORECAST_INTERVAL_MINUTES=30
TRADE_EVAL_INTERVAL_MINUTES=10

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
