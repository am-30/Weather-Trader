# PostgreSQL — Replit native database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Kalshi RSA authentication
# Key ID (short string from Kalshi API settings)
KALSHI_ACCESS_KEY=your-key-id-here
# Full PEM private key content (multiline — paste entire -----BEGIN RSA PRIVATE KEY----- block)
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Kalshi environment: "demo" or "prod"
KALSHI_ENV=demo

# Trading parameters
DRY_RUN=true
EDGE_THRESHOLD=0.05
MAX_TRADE_SIZE_USD=50.0
MAX_CONTRACTS_PER_MARKET=10
KELLY_FRACTION=0.25

# Logging
LOG_LEVEL=INFO
